{
  "gateway": {
    "mode": "local",
    "trustedProxies": [
      "127.0.0.1/32",
      "172.16.0.0/12"
    ],
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "allowedOrigins": [
        "https://ai.euzhi.com",
        "http://127.0.0.1:18800",
        "http://localhost:18800"
      ]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "models": {
        "okinto/gpt-5.4": {
          "alias": "gpt",
          "params": {
            "maxTokens": 12288
          }
        }
      },
      "model": {
        "primary": "okinto/gpt-5.4",
        "fallbacks": []
      },
      "thinkingDefault": "medium",
      "verboseDefault": "off",
      "timeoutSeconds": 1800
    }
  },
  "channels": {
    "wecom": {
      "enabled": true,
      "botId": "${WECOM_BOT_ID}",
      "secret": "${WECOM_BOT_SECRET}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "open",
      "sendThinkingMessage": true
    }
  },
  "tools": {
    "profile": "full",
    "allow": [
      "group:fs",
      "group:runtime",
      "group:sessions",
      "group:web",
      "group:ui",
      "group:nodes",
      "group:automation",
      "image",
      "social_daily_digest",
      "social_mcp_collect_and_report",
      "social_report_build",
      "xiaohongshu_mcp_status",
      "xiaohongshu_mcp_list_tools",
      "xiaohongshu_mcp_call",
      "xiaohongshu_login_status",
      "xiaohongshu_login_start",
      "xiaohongshu_login_qr",
      "xiaohongshu_login_check",
      "xiaohongshu_search_keyword",
      "weibo_mcp_status",
      "weibo_mcp_list_tools",
      "weibo_mcp_call",
      "weibo_trending",
      "weibo_search_keyword",
      "bilibili_mcp_status",
      "bilibili_mcp_list_tools",
      "bilibili_mcp_call",
      "bilibili_search_keyword",
      "douyin_mcp_status",
      "douyin_mcp_list_tools",
      "douyin_mcp_call",
      "douyin_search_keyword",
      "douyin_trending",
      "social_mcp_status",
      "social_mcp_list_tools",
      "social_mcp_call",
      "wecom_doc_quick_report",
      "wecom_doc_mcp_status",
      "wecom_doc_mcp_list_tools",
      "wecom_doc_mcp_call",
      "stream_frame_watch_list_scenarios",
      "stream_frame_watch_analyze"
    ],
    "deny": [],
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "webchat": ["*"]
      }
    },
    "sandbox": {
      "tools": {
        "allow": [
          "exec",
          "process",
          "read",
          "write",
          "edit",
          "apply_patch",
          "image",
          "browser",
          "canvas",
          "nodes",
          "cron",
          "gateway",
          "social_daily_digest",
          "social_mcp_collect_and_report",
          "social_report_build",
          "xiaohongshu_mcp_status",
          "xiaohongshu_mcp_list_tools",
          "xiaohongshu_mcp_call",
          "xiaohongshu_login_status",
          "xiaohongshu_login_start",
          "xiaohongshu_login_qr",
          "xiaohongshu_login_check",
          "xiaohongshu_search_keyword",
          "weibo_mcp_status",
          "weibo_mcp_list_tools",
          "weibo_mcp_call",
          "weibo_trending",
          "weibo_search_keyword",
          "bilibili_mcp_status",
          "bilibili_mcp_list_tools",
          "bilibili_mcp_call",
          "bilibili_search_keyword",
          "douyin_mcp_status",
          "douyin_mcp_list_tools",
          "douyin_mcp_call",
          "douyin_search_keyword",
          "douyin_trending",
          "social_mcp_status",
          "social_mcp_list_tools",
          "social_mcp_call",
          "wecom_doc_quick_report",
          "wecom_doc_mcp_status",
          "wecom_doc_mcp_list_tools",
          "wecom_doc_mcp_call",
          "stream_frame_watch_list_scenarios",
          "stream_frame_watch_analyze",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "sessions_spawn",
          "sessions_yield",
          "subagents",
          "session_status"
        ],
        "deny": []
      }
    },
    "exec": {
      "applyPatch": {
        "enabled": true,
        "allowModels": ["gpt-5.4"]
      }
    }
  },
  "plugins": {
    "allow": ["acpx", "social-mcp", "wecom-openclaw-plugin", "wecom-doc-mcp", "stream-frame-watch"],
    "load": {
      "paths": [
        "/opt/openclaw/plugins/social-mcp",
        "/opt/openclaw/plugins/wecom-doc-mcp",
        "/opt/openclaw/plugins/stream-frame-watch"
      ]
    },
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all"
        }
      },
      "social-mcp": {
        "enabled": true,
        "config": {
          "weiboUrl": "http://weibo-mcp:4200/mcp",
          "xiaohongshuUrl": "http://xhs-mcp:3100/mcp"
        }
      },
      "wecom-openclaw-plugin": {
        "enabled": true,
        "config": {}
      },
      "wecom-doc-mcp": {
        "enabled": true,
        "config": {}
      },
      "stream-frame-watch": {
        "enabled": true,
        "config": {
          "configPath": "/opt/openclaw/config/stream-frame-watch.json"
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "okinto": {
        "baseUrl": "http://127.0.0.1:19080/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-responses",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT-5.4",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 12288
          }
        ]
      }
    }
  }
}
