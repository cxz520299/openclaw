ai.euzhi.com {
  encode zstd gzip

  root * /srv

  @wecom_verify path /WW_verify_ak3J1DHgIiEsYLOh.txt
  handle @wecom_verify {
    root * /srv/reports
    file_server
  }

  handle /reports/* {
    root * /srv/reports
    uri strip_prefix /reports
    file_server browse
  }

  handle /qq/* {
    reverse_proxy qq-bot-bridge:3400
  }

  handle_path /inspection-api/* {
    reverse_proxy inspection-api:8080
  }

  handle_path /inspection-admin/* {
    reverse_proxy inspection-admin:8080
  }

  handle /feishu/* {
    respond "not_found" 404
  }

  handle /app/avatar/* {
    uri strip_prefix /app
    reverse_proxy 172.30.0.10:18789
  }

  handle /app/__openclaw__/* {
    uri strip_prefix /app
    reverse_proxy 172.30.0.10:18789
  }

  handle /ws* {
    reverse_proxy 172.30.0.10:18789 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto {scheme}
    }
  }

  handle /app/* {
    try_files {path} /app/index.html
    file_server
  }

  handle /openclaw-control-shell.html {
    file_server
  }

  handle {
    try_files /index.html
    file_server
  }
}
