ai.euzhi.com {
  encode zstd gzip

  handle /reports/* {
    root * /srv/reports
    uri strip_prefix /reports
    file_server browse
  }

  handle /qq/* {
    reverse_proxy qq-bot-bridge:3400
  }

  handle {
    reverse_proxy openclaw-gateway:18789 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      header_up X-Forwarded-Proto {scheme}
    }
  }
}
